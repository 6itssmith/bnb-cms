# Same Supabase project as the guest site (aura-crib / BNB_DEMO).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Server-only — used by app/api/bookings/[id]/refund and to call the
# refund-payment Edge Function. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional: only read by the Settings page to show a configured/not-configured
# indicator for payment providers. The real secrets live in Supabase Edge
# Function secrets (see PAYMENT_SANDBOX_SETUP.md in the guest site repo) —
# setting these here does not configure payments, it only affects that one
# status display.
MPESA_CONSUMER_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
